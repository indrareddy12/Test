# Greencare AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Groq Cloud API ─────────────────────────────────────────────────────────
# Obtain your key from https://console.groq.com/keys
GROQ_API_KEY=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  

# ── Groq Model (optional override) ────────────────────────────────────────
# Available vision models: llama-3.2-90b-vision-preview, llama-3.2-11b-vision-preview
GROQ_MODEL=llama-3.2-90b-vision-preview
GROQ_MAX_TOKENS=4096

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Internal service URLs (used only when running without Docker) ──────────
LEGO2_URL=http://localhost:8001
LEGO3_URL=http://localhost:8002
